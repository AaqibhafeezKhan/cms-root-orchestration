{
  "version": 2,
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/index.html" },
    { "source": "/editorial/(.*)", "destination": "/index.html" },
    { "source": "/collab/(.*)", "destination": "/index.html" },
    { "source": "/media/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
